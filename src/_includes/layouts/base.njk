<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ (description or site.description) | escape }}">
    <meta name="theme-color" content="#f3f3ef">
    <meta property="og:title" content="{% if title %}{{ title | escape }} · {% endif %}{{ site.name | escape }}">
    <meta property="og:description" content="{{ (description or site.description) | escape }}">
    <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}/assets/avatar.png">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/feed.xml">
    <link rel="icon" href="/assets/avatar.png">
    <link rel="stylesheet" href="/assets/styles.css">
    <link rel="stylesheet" href="/assets/article-content.css">
    <link rel="stylesheet" href="/assets/katex.min.css">
    <title>{% if title %}{{ title | escape }} · {% endif %}{{ site.name | escape }}</title>
    <script>
      document.documentElement.dataset.theme =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">跳到主要内容</a>

    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="Zinc Acetate 博客首页">
          <span class="brand-mark" aria-hidden="true">ZA</span>
          <span class="brand-copy">
            <strong>Zinc Acetate</strong>
            <small>Algorithm Notes</small>
          </span>
        </a>

        <nav class="site-nav" id="site-nav" aria-label="主导航">
          <a href="/" {% if page.url == '/' %}aria-current="page"{% endif %}>首页</a>
          <a href="/archive/" {% if page.url == '/archive/' %}aria-current="page"{% endif %}>文章</a>
          <a href="/projects/" {% if page.url == '/projects/' %}aria-current="page"{% endif %}>项目</a>
          <a href="/about/" {% if page.url == '/about/' %}aria-current="page"{% endif %}>关于</a>
          <a href="{{ site.admin }}" target="_blank" rel="noreferrer">管理</a>
          <a href="{{ site.github }}" target="_blank" rel="noreferrer">GitHub</a>
        </nav>

        <div class="header-tools">
          <button class="icon-button" id="search-toggle" type="button" aria-label="搜索文章">
            <i data-lucide="search" aria-hidden="true"></i>
          </button>
          <button class="icon-button" id="theme-toggle" type="button" aria-label="切换深浅色主题">
            <i data-lucide="sun" aria-hidden="true"></i>
          </button>
          <button
            class="icon-button nav-toggle"
            id="nav-toggle"
            type="button"
            aria-label="打开导航"
            aria-controls="site-nav"
            aria-expanded="false"
          >
            <i data-lucide="menu" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </header>

    <main id="main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <strong>{{ site.name }}</strong>
          <span>记录训练、比赛与思考。</span>
        </div>
        <div class="footer-links">
          <a href="/feed.xml">RSS</a>
          <a href="{{ site.admin }}" target="_blank" rel="noreferrer">管理</a>
          <a href="{{ site.github }}" target="_blank" rel="noreferrer">GitHub</a>
          <span>© <span id="current-year"></span></span>
        </div>
      </div>
    </footer>

    <dialog class="search-dialog" id="search-dialog">
      <div class="search-header">
        <label for="search-input">搜索文章</label>
        <button class="icon-button" id="search-close" type="button" aria-label="关闭搜索">
          <i data-lucide="x" aria-hidden="true"></i>
        </button>
      </div>
      <div class="search-field">
        <i data-lucide="search" aria-hidden="true"></i>
        <input id="search-input" type="search" placeholder="输入标题、分类或关键词" autocomplete="off">
      </div>
      <div class="search-results" id="search-results" aria-live="polite">
        <p class="search-empty">输入关键词开始搜索。</p>
      </div>
    </dialog>

    <script src="https://unpkg.com/lucide@0.468.0/dist/umd/lucide.min.js"></script>
    <script type="module" src="/assets/script.js"></script>
  </body>
</html>
