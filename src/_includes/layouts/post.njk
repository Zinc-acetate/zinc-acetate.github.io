---
layout: layouts/base.njk
---
<article class="article-shell">
  <header class="article-header">
    <a class="back-link" href="/archive/">
      <i data-lucide="arrow-left" aria-hidden="true"></i> 返回文章列表
    </a>
    <div class="article-kicker">
      <span>{{ category }}</span>
      <time datetime="{{ date | htmlDate }}">{{ date | readableDate }}</time>
      <span>{{ readingTime }}</span>
    </div>
    <h1>{{ title }}</h1>
    <p>{{ description }}</p>
  </header>

  <div class="article-layout">
    <aside class="article-rail" aria-label="文章信息">
      <span>WRITTEN BY</span>
      <strong>{{ site.author }}</strong>
      <a href="{{ site.codeforces }}" target="_blank" rel="noreferrer">Codeforces</a>
    </aside>
    <div class="article-content">
      {{ content | safe }}
    </div>
  </div>

  <footer class="article-footer">
    <p>继续阅读与训练。</p>
    <a class="text-link" href="/archive/">查看全部文章 <i data-lucide="arrow-right" aria-hidden="true"></i></a>
  </footer>
</article>
