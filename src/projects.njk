---
layout: layouts/base.njk
title: 项目
description: Zinc Acetate 的公开 GitHub 项目。
permalink: /projects/index.html
---
<section class="page-heading">
  <div class="page-width" data-reveal>
    <p class="overline"><span aria-hidden="true"></span> CODE / PROJECTS</p>
    <h1>项目</h1>
    <p>公开仓库与一些阶段性的实践记录。内容每天从 GitHub 自动同步。</p>
  </div>
</section>

<section class="projects-section" aria-labelledby="projects-title">
  <div class="page-width">
    <header class="section-header" data-reveal>
      <div>
        <p class="section-label">01 / REPOSITORIES</p>
        <h2 id="projects-title">公开仓库</h2>
      </div>
      <a class="text-link" href="{{ site.github }}?tab=repositories" target="_blank" rel="noreferrer">
        GitHub <i data-lucide="arrow-up-right" aria-hidden="true"></i>
      </a>
    </header>
    <div class="project-grid">
{% for project in projects %}
      <a class="project-card" href="{{ project.html_url }}" target="_blank" rel="noreferrer" data-reveal data-pointer-depth>
        <div class="project-topline">
          <span>{{ project.language | escape }}</span>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </div>
        <div>
          <h3>{{ project.name | escape }}</h3>
          <p>{{ project.description | escape }}</p>
        </div>
        <div class="project-footer">
          <span>{{ project.stargazers_count }} stars</span>
          <span>{{ project.pushed_at | projectDate }}</span>
        </div>
      </a>
{% endfor %}
    </div>
  </div>
</section>
