---
layout: layouts/base.njk
title: 首页
description: Zinc Acetate 的算法竞赛博客，记录 ACM 训练、比赛复盘、题解与开发日志。
---
<section class="intro-section" aria-labelledby="intro-title" data-signal-scene>
  <canvas class="signal-canvas" data-signal-canvas aria-hidden="true"></canvas>
  <div class="hero-axis hero-axis-x" aria-hidden="true"></div>
  <div class="hero-axis hero-axis-y" aria-hidden="true"></div>
  <div class="page-width intro-grid">
    <div class="intro-copy" data-reveal>
      <p class="overline"><span aria-hidden="true"></span> ACM / ALGORITHMS / NOTES <i aria-hidden="true"></i></p>
      <h1 id="intro-title">Zinc Acetate</h1>
      <p class="intro-lead">一名 ACMer。写比赛，写算法，也写那些值得留下的思考。</p>
      <div class="intro-actions">
        <a class="button button-primary" href="/archive/">
          阅读文章 <i data-lucide="arrow-right" aria-hidden="true"></i>
        </a>
        <a class="button button-secondary" href="/about/">关于我</a>
      </div>

      <dl class="hero-telemetry">
        <div>
          <dt>FOCUS</dt>
          <dd>Algorithms</dd>
        </div>
        <div>
          <dt>MODE</dt>
          <dd>Contest / Review</dd>
        </div>
        <div>
          <dt>STATUS</dt>
          <dd><span aria-hidden="true"></span> Training</dd>
        </div>
      </dl>
    </div>

    <div class="identity-panel" data-reveal data-reveal-delay="2">
      <div class="identity-visual" data-pointer-depth>
        <span class="identity-corner identity-corner-top" aria-hidden="true"></span>
        <img src="/assets/avatar.png" alt="Zinc Acetate 的头像" width="460" height="460">
        <span class="identity-corner identity-corner-bottom" aria-hidden="true"></span>
        <span class="identity-index" aria-hidden="true">ZA / 01</span>
      </div>
      <div class="identity-copy">
        <span>COMPETITIVE PROGRAMMER</span>
        <strong>在约束中寻找<br>更优的答案。</strong>
        <div class="identity-medals">
          <span><b>AG</b> 区域赛银牌</span>
          <span><b>AU</b> 邀请赛金牌</span>
        </div>
      </div>
    </div>
  </div>

  <div class="page-width achievement-bar" role="group" aria-label="竞赛概况" data-reveal>
    <a href="{{ site.codeforces }}" target="_blank" rel="noreferrer" data-platform="01">
      <span>Codeforces</span>
      <strong data-cf-rating>2341</strong>
      <small data-cf-rank>International Master</small>
    </a>
    <a href="{{ site.atcoder }}" target="_blank" rel="noreferrer" data-platform="02">
      <span>AtCoder</span>
      <strong>ZnAc_2</strong>
      <small>Profile</small>
    </a>
    <a href="{{ site.luogu }}" target="_blank" rel="noreferrer" data-platform="03">
      <span>洛谷</span>
      <strong>117917</strong>
      <small>Zinc_acetate</small>
    </a>
  </div>
</section>

<section class="posts-section" aria-labelledby="latest-title">
  <div class="page-width content-grid">
    <div class="posts-column">
      <header class="section-header" data-reveal>
        <div>
          <p class="section-label">01 / LATEST</p>
          <h2 id="latest-title">最近文章</h2>
        </div>
        <a class="text-link" href="/archive/">全部文章 <i data-lucide="arrow-right" aria-hidden="true"></i></a>
      </header>

      <div class="post-list">
{% for post in collections.blogPosts | head(4) %}
          <article class="post-row" data-reveal>
            <div class="post-date">
              <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate }}</time>
              <span>{{ post.data.category | escape }}</span>
{% if post.data.pinned %}<span class="pinned-label">置顶</span>{% endif %}
            </div>
            <div class="post-summary">
              <h3><a href="{{ post.url }}">{{ post.data.title | escape }}</a></h3>
              <p>{{ post.data.description | escape }}</p>
            </div>
            <div class="post-read">
              <span>{{ post.data.readingTime | escape }}</span>
              <a href="{{ post.url }}" aria-label="阅读《{{ post.data.title | escape }}》">
                <i data-lucide="arrow-up-right" aria-hidden="true"></i>
              </a>
            </div>
          </article>
{% endfor %}
      </div>
    </div>

    <aside class="profile-column" aria-labelledby="profile-title" data-reveal data-reveal-delay="2">
      <p class="section-label">02 / PROFILE</p>
      <h2 id="profile-title">赛场坐标</h2>
      <p>把一道题想明白，把一场比赛复盘清楚。这个博客记录其中的过程。</p>
      <div class="profile-links">
        <a href="{{ site.codeforces }}" target="_blank" rel="noreferrer">
          <span>Codeforces</span>
          <strong>Zinc-acetate</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="{{ site.atcoder }}" target="_blank" rel="noreferrer">
          <span>AtCoder</span>
          <strong>ZnAc_2</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="{{ site.luogu }}" target="_blank" rel="noreferrer">
          <span>洛谷</span>
          <strong>Zinc_acetate</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
      </div>
    </aside>
  </div>
</section>

<section class="project-entry-section" aria-label="项目页面入口">
  <a class="page-width project-entry" href="/projects/" data-reveal>
    <span>
      <small>03 / PROJECTS</small>
      <strong>代码与项目</strong>
    </span>
    <span>
      浏览 GitHub 项目
      <i data-lucide="arrow-up-right" aria-hidden="true"></i>
    </span>
  </a>
</section>
