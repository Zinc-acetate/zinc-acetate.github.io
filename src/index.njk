---
layout: layouts/base.njk
title: 首页
description: Zinc Acetate 的算法竞赛博客，记录 ACM 训练、比赛复盘、题解与开发日志。
---
<section class="intro-section" aria-labelledby="intro-title">
  <div class="page-width intro-grid">
    <div class="intro-copy">
      <p class="overline"><span aria-hidden="true"></span> ACM / ALGORITHMS / NOTES</p>
      <h1 id="intro-title">Zinc Acetate</h1>
      <p class="intro-lead">一名 ACMer。写比赛，写算法，也写那些值得留下的思考。</p>
      <div class="intro-actions">
        <a class="button button-primary" href="/archive/">
          阅读文章 <i data-lucide="arrow-right" aria-hidden="true"></i>
        </a>
        <a class="button button-secondary" href="/about/">关于我</a>
      </div>
    </div>

    <div class="identity-panel">
      <img src="/assets/avatar.png" alt="Zinc Acetate 的头像" width="460" height="460">
      <div class="identity-copy">
        <span>COMPETITIVE PROGRAMMER</span>
        <strong>区域赛银牌<br>邀请赛金牌</strong>
      </div>
    </div>
  </div>

  <div class="page-width achievement-bar" role="group" aria-label="竞赛概况">
    <a href="{{ site.codeforces }}" target="_blank" rel="noreferrer">
      <span>Codeforces</span>
      <strong data-cf-rating>2341</strong>
      <small data-cf-rank>International Master</small>
    </a>
    <a href="{{ site.atcoder }}" target="_blank" rel="noreferrer">
      <span>AtCoder</span>
      <strong>ZnAc_2</strong>
      <small>Profile</small>
    </a>
    <a href="{{ site.luogu }}" target="_blank" rel="noreferrer">
      <span>洛谷</span>
      <strong>117917</strong>
      <small>Zinc_acetate</small>
    </a>
  </div>
</section>

<section class="posts-section" aria-labelledby="latest-title">
  <div class="page-width content-grid">
    <div class="posts-column">
      <header class="section-header">
        <div>
          <p class="section-label">01 / LATEST</p>
          <h2 id="latest-title">最近文章</h2>
        </div>
        <a class="text-link" href="/archive/">全部文章 <i data-lucide="arrow-right" aria-hidden="true"></i></a>
      </header>

      <div class="post-list">
{% for post in collections.blogPosts | head(4) %}
          <article class="post-row">
            <div class="post-date">
              <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate }}</time>
              <span>{{ post.data.category }}</span>
            </div>
            <div class="post-summary">
              <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
              <p>{{ post.data.description }}</p>
            </div>
            <div class="post-read">
              <span>{{ post.data.readingTime }}</span>
              <a href="{{ post.url }}" aria-label="阅读《{{ post.data.title }}》">
                <i data-lucide="arrow-up-right" aria-hidden="true"></i>
              </a>
            </div>
          </article>
{% endfor %}
      </div>
    </div>

    <aside class="profile-column" aria-labelledby="profile-title">
      <p class="section-label">02 / PROFILE</p>
      <h2 id="profile-title">赛场坐标</h2>
      <p>把一道题想明白，把一场比赛复盘清楚。这个博客记录其中的过程。</p>
      <div class="profile-links">
        <a href="{{ site.codeforces }}" target="_blank" rel="noreferrer">
          <span>Codeforces</span>
          <strong>Zinc-acetate</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="{{ site.atcoder }}" target="_blank" rel="noreferrer">
          <span>AtCoder</span>
          <strong>ZnAc_2</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
        <a href="{{ site.luogu }}" target="_blank" rel="noreferrer">
          <span>洛谷</span>
          <strong>Zinc_acetate</strong>
          <i data-lucide="arrow-up-right" aria-hidden="true"></i>
        </a>
      </div>
    </aside>
  </div>
</section>

<section class="projects-section" aria-labelledby="projects-title">
  <div class="page-width">
    <header class="section-header">
      <div>
        <p class="section-label">03 / GITHUB</p>
        <h2 id="projects-title">最近项目</h2>
      </div>
      <a class="text-link" href="{{ site.github }}?tab=repositories" target="_blank" rel="noreferrer">
        GitHub <i data-lucide="arrow-up-right" aria-hidden="true"></i>
      </a>
    </header>
    <div class="project-grid" id="github-projects">
{% for project in projects %}
        <a class="project-card" href="{{ project.html_url }}" target="_blank" rel="noreferrer">
          <div class="project-topline">
            <span>{{ project.language }}</span>
            <i data-lucide="arrow-up-right" aria-hidden="true"></i>
          </div>
          <div>
            <h3>{{ project.name }}</h3>
            <p>{{ project.description }}</p>
          </div>
          <div class="project-footer">
            <span>{{ project.stargazers_count }} stars</span>
            <span>{{ project.pushed_at | projectDate }}</span>
          </div>
        </a>
{% endfor %}
    </div>
  </div>
</section>
